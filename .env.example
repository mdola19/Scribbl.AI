# Base URL for Ollama (no trailing slash). Use the same host your Next server can reach.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Legacy alias also supported by the app:
# OLLAMA_HOST=http://127.0.0.1:11434

# Vision-capable model pulled into Ollama (must match `ollama pull …`)
OLLAMA_MODEL=llama3.2-vision
